    // CART STATE
    var cart = {};

    function getQty(id) { return parseInt(document.getElementById('qty-'+id)?.textContent||'1'); }

    function changeQty(id, delta) {
      var el = document.getElementById('qty-'+id);
      if (!el) return;
      var v = Math.max(1, parseInt(el.textContent)+delta);
      el.textContent = v;
    }

    function addToCart(id, qty) {
      qty = qty || getQty(id);
      if (!cart[id]) cart[id] = 0;
      cart[id] += qty;
      updateCartUI();
      // Button feedback
      var btn = document.getElementById('cart-btn-'+id);
      if (btn) {
        btn.classList.add('added');
        btn.innerHTML = '<i class="fi fi-rr-check"></i> Added!';
        setTimeout(function(){
          btn.classList.remove('added');
          btn.innerHTML = '<i class="fi fi-rr-shopping-cart"></i> Add to Cart';
        }, 1600);
      }
      // Badge bump
      var badge = document.getElementById('cart-badge');
      badge.classList.add('bump');
      setTimeout(function(){ badge.classList.remove('bump'); }, 300);
    }

    function removeFromCart(id) {
      delete cart[id];
      updateCartUI();
    }

    function updateCartUI() {
      var total = 0, count = 0;
      var itemsEl = document.getElementById('cart-items');
      var keys = Object.keys(cart);
      if (!keys.length) {
        itemsEl.innerHTML = '<div class="cart-empty"><i class="fi fi-rr-shopping-cart"></i><p>Your cart is empty</p></div>';
        document.getElementById('cart-total').textContent = '\u20B10';
        document.getElementById('cart-badge').textContent = '0';
        return;
      }
      var html = '';
      keys.forEach(function(id){
        var p = PRODUCTS[id]; if(!p) return;
        var qty = cart[id];
        count += qty;
        total += p.priceRaw * qty;
        html += '<div class="cart-item">'+
          '<div class="cart-item-img"><i class="fi fi-rr-box-open-full"></i></div>'+
          '<div>'+
            '<div class="cart-item-name">'+p.name+'</div>'+
            '<div class="cart-item-price">'+p.price+' &times; '+qty+'</div>'+
            '<div class="cart-item-qty">Subtotal: \u20B1'+( p.priceRaw*qty ).toLocaleString()+'</div>'+
          '</div>'+
          '<button class="cart-item-remove" onclick="removeFromCart(\''+id+'\')"><i class="fi fi-rr-trash"></i></button>'+
        '</div>';
      });
      itemsEl.innerHTML = html;
      document.getElementById('cart-total').textContent = '\u20B1' + total.toLocaleString();
      document.getElementById('cart-badge').textContent = count;
    }

    function toggleCart() {
      document.getElementById('cart-drawer').classList.toggle('open');
    }
    document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ closeProdModal(); document.getElementById('cart-drawer').classList.remove('open'); } });

    // FILTER
    function filterShop(cat, btn) {
      document.querySelectorAll('.shop-filter-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var rows = document.querySelectorAll('.product-row');
      var shown = 0;
      rows.forEach(function(row){
        var id = row.id.replace('prod-','');
        var p = PRODUCTS[id];
        var match = cat === 'all' || (p && p.cat === cat);
        row.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      document.getElementById('shop-count').textContent = 'Showing ' + shown + ' item' + (shown !== 1 ? 's' : '');
    }

    // PRODUCT MODAL
    var currentModalId = null;
    function openProdModal(id) {
      currentModalId = id;
      var p = PRODUCTS[id]; if(!p) return;
      document.getElementById('prod-modal-title').textContent = p.name;
      document.getElementById('prod-modal-cat').textContent   = p.cat;
      document.getElementById('prod-modal-price').textContent = p.price;
      document.getElementById('prod-modal-desc').textContent  = p.desc;
      var specsHtml = p.specs.map(function(s){
        return '<div class="prod-modal-spec-row"><span class="prod-modal-spec-key">'+s[0]+'</span><span class="prod-modal-spec-val">'+s[1]+'</span></div>';
      }).join('');
      document.getElementById('prod-modal-specs').innerHTML = specsHtml;
      var stk = p.stock === 'in-stock' ? '<span class="stock-badge in-stock"><span class="stock-dot"></span>In Stock</span>' : '<span class="stock-badge low-stock"><span class="stock-dot"></span>Low Stock</span>';
      document.getElementById('prod-modal-stock').innerHTML = stk;
      document.getElementById('prod-modal-overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeProdModal() {
      document.getElementById('prod-modal-overlay').classList.remove('open');
      document.body.style.overflow = '';
    }
    function closeProdModalOutside(e) {
      if (e.target === document.getElementById('prod-modal-overlay')) closeProdModal();
    }
    function addToCartFromModal() {
      if (currentModalId) { addToCart(currentModalId, 1); closeProdModal(); }
    }
  </script>
</body>
</html>
