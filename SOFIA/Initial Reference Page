          <div class="video-card reveal reveal-delay-1">
            <div class="video-thumb-wrap">
              <iframe
                src="https://www.youtube.com/embed/Fpnl4VbqkMk"
                title="Creotec Robotics Tutorial Lesson 2"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen loading="lazy">
              </iframe>
              <div class="video-scan-overlay" aria-hidden="true"></div>
            </div>
            <div class="video-card-body">
              <div class="video-card-top">
                <span class="video-yt-badge"><i class="fi fi-brands-youtube"></i> YouTube</span>
