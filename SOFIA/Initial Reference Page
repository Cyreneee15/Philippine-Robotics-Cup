      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ===== DOCUMENT REFERENCES ===== -->
    <section id="doc-references" aria-label="Document References">
      <div class="section-inner">
        <div class="references-header reveal">
          <div class="section-eyebrow">Sources &amp; Documents</div>
          <h2 class="references-title">Official <span class="accent">References</span></h2>
          <p class="references-desc">
            Official registrations, publications, and external resources cited in relation
            to Creotec Philippines and the Philippine Robotics Cup.
          </p>
