            <div>
              <div class="playlist-label">Creotec Philippines</div>
              <div class="playlist-title">Robotics <span>Tutorial Series</span></div>
              <div class="playlist-count">3 lessons available &nbsp;·&nbsp; More coming soon</div>
            </div>
          </div>
          <a href="https://www.youtube.com/@creotecphilippines" target="_blank" rel="noopener" class="btn-neon-primary">
            <i class="fi fi-brands-youtube"></i> Visit YouTube Channel
          </a>
